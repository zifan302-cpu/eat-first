# Copy this file to .env.local. Never commit .env.local or paste the key into client code.
QWEN_API_KEY=
# Copy the OpenAI-compatible API base URL for the same Alibaba Cloud region/workspace as the key.
# Example shape: https://YOUR_WORKSPACE.REGION.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=
QWEN_MODEL=qwen3.7-plus
PORT=5173

# Optional: identify this app to Open Food Facts with a contact URL or email.
OPEN_FOOD_FACTS_USER_AGENT=FridgeFreshSquad/0.6 (https://github.com/zifan302-cpu/eat-first)
