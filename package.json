{
  "name": "eat-first",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "dev": "node --env-file-if-exists=.env.local server/index.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --project tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node --env-file-if-exists=.env.local server/index.mjs --production",
    "test": "vitest run --environment jsdom --globals --cache false"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
